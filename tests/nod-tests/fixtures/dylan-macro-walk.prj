# Sprint 52.5 — module-walk expansion driver.
#
# Bundles the Dylan-side lexer + macro engine + the walk driver into an
# EXE whose entry point (`walk-main`) prints WALK lines for a fixed set of
# (define-macros, input-source) cases. The gate
# `tests/nod-tests/tests/macro_walk.rs` checks each against a
# hand-verified expectation (find-in-stream, passthrough, fixpoint
# recursion, multi-rule selection, sibling calls).

name           = "dylan-macro-walk"
sources        = ["../../../compiler/dylan-lexer.dylan", "../../../compiler/dylan-macro.dylan", "dylan-macro-walk.dylan"]
output         = "dylan-macro-walk.exe"
start_function = "walk-main"
